#!/bin/bash
#
# Git pre-receive hook to validate commit messages against Conventional Commits format
#
# This hook runs on the server before any refs are updated and rejects pushes
# if any commit doesn't follow the Conventional Commits format.
#
# Installation:
#   Copy this file to your Git server's hooks directory:
#   cp .github/hooks/pre-receive /path/to/repository.git/hooks/pre-receive
#   chmod +x /path/to/repository.git/hooks/pre-receive

# ANSI color codes for better error messages
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Valid commit types according to Conventional Commits
VALID_TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Exit codes
EXIT_SUCCESS=0
EXIT_FAILURE=1

# Flag to track if any commit is invalid
has_invalid_commits=0

# Function to print error messages
print_error() {
    echo -e "${RED}ERROR:${NC} $1" >&2
}

# Function to print warning messages
print_warning() {
    echo -e "${YELLOW}WARNING:${NC} $1" >&2
}

# Function to print info messages
print_info() {
    echo -e "${BLUE}INFO:${NC} $1" >&2
}

# Function to print success messages
print_success() {
    echo -e "${GREEN}SUCCESS:${NC} $1" >&2
}

# Function to print usage examples
print_examples() {
    cat >&2 <<EOF

${GREEN}Valid commit message examples:${NC}
  feat: add user authentication
  fix(api): resolve null pointer exception
  docs: update README with installation steps
  refactor(database): optimize query performance
  test: add unit tests for user service
  chore(deps): update dependencies

${RED}Invalid commit message examples:${NC}
  added new feature                    (missing type prefix)
  FIX: bug fix                         (type must be lowercase)
  feat:missing space after colon       (missing space after colon)
  feat: Add feature.                   (subject ends with period)
  invalid: commit message              (invalid type)
  feat: Add Feature                    (subject should start lowercase)

${BLUE}Format:${NC}
  <type>(<scope>): <subject>

  Where:
  - type: One of ${VALID_TYPES}
  - scope: Optional, in parentheses
  - subject: Brief description, lowercase, no ending period

EOF
}

# Function to validate a single commit message
validate_commit_message() {
    local commit_sha="$1"
    local commit_message="$2"
    
    # Get the first line (subject) of the commit message
    local subject_line=$(echo "$commit_message" | head -n 1)
    
    # Check if the commit message matches the basic pattern
    # Pattern: <type>(<optional-scope>): <subject>
    # The type must be one of the valid types
    # The scope is optional and must be in parentheses
    # There must be a colon followed by a space
    # The subject must exist
    
    # Regular expression for Conventional Commits format
    # ^(type)(\(scope\))?: subject$
    local pattern="^(${VALID_TYPES})(\([a-z0-9-]+\))?: .+$"
    
    if ! echo "$subject_line" | grep -qE "$pattern"; then
        print_error "Invalid commit message format in commit ${commit_sha:0:7}"
        echo -e "${YELLOW}Commit message:${NC}" >&2
        echo "$subject_line" >&2
        echo "" >&2
        
        # Provide specific feedback on what's wrong
        if ! echo "$subject_line" | grep -qE "^(${VALID_TYPES})"; then
            local first_word=$(echo "$subject_line" | cut -d':' -f1 | cut -d'(' -f1)
            if [[ -z "$first_word" ]]; then
                print_error "  → Missing commit type"
            elif echo "$first_word" | grep -qE "^[A-Z]"; then
                print_error "  → Type must be lowercase (found: '$first_word')"
            else
                print_error "  → Invalid type '$first_word' (must be one of: ${VALID_TYPES})"
            fi
        fi
        
        if ! echo "$subject_line" | grep -q ": "; then
            if echo "$subject_line" | grep -q ":"; then
                print_error "  → Missing space after colon"
            else
                print_error "  → Missing colon and space after type/scope"
            fi
        fi
        
        echo "" >&2
        return $EXIT_FAILURE
    fi
    
    # Additional validations for messages that match the basic pattern
    # Check if subject starts with uppercase (after ": ")
    if echo "$subject_line" | grep -qE ": [A-Z]"; then
        print_error "Invalid commit message in commit ${commit_sha:0:7}"
        echo -e "${YELLOW}Commit message:${NC}" >&2
        echo "$subject_line" >&2
        print_error "  → Subject should start with lowercase letter" >&2
        echo "" >&2
        return $EXIT_FAILURE
    fi
    
    # Check if subject ends with a period
    if echo "$subject_line" | grep -qE "\.$"; then
        print_error "Invalid commit message in commit ${commit_sha:0:7}"
        echo -e "${YELLOW}Commit message:${NC}" >&2
        echo "$subject_line" >&2
        print_error "  → Subject should not end with a period" >&2
        echo "" >&2
        return $EXIT_FAILURE
    fi
    
    return $EXIT_SUCCESS
}

# Main validation logic
echo "" >&2
print_info "Validating commit messages against Conventional Commits format..." >&2
echo "" >&2

# Read from stdin: old-value new-value ref-name
while read oldrev newrev refname; do
    # Skip if this is a branch deletion
    if [ "$newrev" = "0000000000000000000000000000000000000000" ]; then
        continue
    fi
    
    # If this is a new branch, only validate commits not in any other branch
    # This avoids re-validating the entire history for branches created from existing branches
    if [ "$oldrev" = "0000000000000000000000000000000000000000" ]; then
        # Get commits that are new to the repository (not in any other ref)
        # This is efficient even for new branches with large histories
        commits=$(git rev-list "$newrev" --not --branches='*' --remotes='*' 2>/dev/null || git rev-list "$newrev")
    else
        # For existing branches, only validate new commits
        range="$oldrev..$newrev"
        commits=$(git rev-list "$range")
    fi
    
    # Iterate through each commit
    for commit in $commits; do
        # Get the commit message
        commit_message=$(git log -1 --format=%B "$commit")
        
        # Validate the commit message
        if ! validate_commit_message "$commit" "$commit_message"; then
            has_invalid_commits=1
        fi
    done
done

# If any commits were invalid, reject the push
if [ $has_invalid_commits -eq 1 ]; then
    echo "" >&2
    print_error "Push rejected: One or more commits have invalid commit messages" >&2
    print_examples
    exit $EXIT_FAILURE
fi

# All commits are valid
echo "" >&2
print_success "All commit messages are valid!" >&2
echo "" >&2
exit $EXIT_SUCCESS
